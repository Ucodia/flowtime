{
  "name": "flowtime",
  "version": "1.1.0",
  "description": "An unpredictable time library for JavaScript",
  "license": "MIT",
  "author": "Lionel Ringenbach <lionel@ucodia.space> (https://ucodia.space)",
  "main": "dist/flowtime.js",
  "umd:main": "dist/flowtime.umd.js",
  "module": "dist/flowtime.mjs",
  "source": "src/index.js",
  "scripts": {
    "prepare": "npm run build",
    "build": "microbundle",
    "dev": "microbundle watch",
    "format": "prettier --write \"{src,test}/**/*.js\"",
    "test": "jest --coverage --ci",
    "watch": "jest --watch",
    "demo": "npm run build && open dist/index.html"
  },
  "devDependencies": {
    "babel-core": "^6.26.3",
    "babel-jest": "^23.4.0",
    "babel-preset-env": "^1.7.0",
    "jest": "^22.4.0",
    "microbundle": "^0.6.0",
    "prettier": "^1.13.5"
  },
  "jest": {
    "transform": {
      "^.+\\.js$": "babel-jest"
    }
  }
}
